# Git 忽略文件 - .gitignore - 列出不应提交到仓库的文件与目录

# Node modules
node_modules/

# Build output
dist/
build/
.vite/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Runtime data
pids/
*.pid
*.seed

# Dependency directories
jspm_packages/

# Coverage
coverage/

# Environment files
.env
.env.*.local

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Test outputs
test-results/

# Misc
*.local

# Lock files (keep if you prefer to track them)
# package-lock.json
# yarn.lock

# Dist cache
.cache/

# Optional: ignore compiled files
*.tsbuildinfo

# End of .gitignore
